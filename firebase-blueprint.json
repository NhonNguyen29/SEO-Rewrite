{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile, API keys, and token usage.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "geminiApiKey": {
          "type": "string",
          "description": "The user's personal Gemini API key."
        },
        "tokensUsed": {
          "type": "number",
          "description": "Total tokens used by the user."
        },
        "quotaLimit": {
          "type": "number",
          "description": "The user's token quota limit."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and API settings."
    }
  }
}
